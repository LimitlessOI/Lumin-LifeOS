# Environment Template
# Define all possible environment variables with descriptions and validation rules

# Server Configuration
PORT=3000 # The port your server will run on
SMOKE_MODE=0 # Set to 1/true to disable background loops for smoke verification
AUTONOMY_SMOKE=0 # Alternate smoke flag (same effect as SMOKE_MODE)
COUNCIL_TIMEOUT_MS=300000 # Max council call timeout in ms
COUNCIL_PING_TIMEOUT_MS=5000 # Timeout for /api/v1/chat ping checks in ms
PAUSE_AUTONOMY=0 # Set to 1/true to disable all background/autonomy loops
QUIET_HOURS= # Format HH:MM-HH:MM (local time). Heavy work is blocked during this window.
HEAVY_HOURS= # Format HH:MM-HH:MM (local time). Heavy work allowed only in this window.
IDLE_AFTER_MS=120000 # No-request window to consider idle
IDLE_LOAD_THRESHOLD=0.7 # 1-minute load threshold for idle detection
OLLAMA_FAILURE_THRESHOLD=3 # Consecutive failures before opening circuit breaker
OLLAMA_COOLDOWN_MS=900000 # Cooldown window for Ollama circuit breaker

# Database Configuration
DB_HOST=localhost # Database host
DB_PORT=5432 # Database port
DB_USER=user # Database user
DB_PASSWORD=password # Database password

# Stripe Configuration
STRIPE_API_KEY=sk_test_1234567890abcdefg # Your Stripe API key

# Search safety controls (safe internet access)
SEARCH_ENABLED=true
SEARCH_API_URL=https://api.duckduckgo.com/
SEARCH_DAILY_LIMIT=100
SEARCH_RATE_LIMIT_PER_MINUTE=10
SEARCH_TIMEOUT=10000
# Email (NotificationService — Postmark recommended)
EMAIL_PROVIDER=postmark          # "postmark" | "disabled"
EMAIL_FROM=hello@yourdomain.com  # Default From address for all outbound emails
POSTMARK_SERVER_TOKEN=           # Postmark Server API Token (from postmark.com → Server → API Tokens)
EMAIL_WEBHOOK_SECRET=            # Shared secret for Postmark bounce/complaint webhooks

# Site Builder + Prospect Pipeline
SITE_BASE_URL=https://yourapp.railway.app  # Public base URL for preview site links in cold emails

# POS Affiliate Commission Partners
# Sign up for each affiliate program and paste the tracking URLs here:
#   Jane App:  https://jane.app/affiliates
#   Mindbody:  https://www.mindbodyonline.com/partner
#   Square:    https://squareup.com/us/en/referral
AFFILIATE_JANE_APP_URL=          # Your Jane App affiliate tracking link
AFFILIATE_MINDBODY_URL=          # Your Mindbody affiliate tracking link
AFFILIATE_SQUARE_URL=            # Your Square affiliate/referral link

# Add more environment variables as needed
