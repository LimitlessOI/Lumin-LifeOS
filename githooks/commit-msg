#!/bin/sh
# §2.11 BUILDER-FIRST + §2.15 INTENT DRIFT + BP receipt co-commit
# Tracked: githooks/commit-msg → install via npm run hooks:install
# @ssot docs/projects/AMENDMENT_19_PROJECT_GOVERNANCE.md

ROOT="$(git rev-parse --show-toplevel)"
COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# ── 1. §2.11 Builder-first gate ───────────────────────────────────────────────
STAGED_PRODUCT=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
  | grep -E '^(routes/|services/|public/overlay/|db/migrations/)' \
  | grep -v 'lifeos-council-builder-routes\.js' || true)

if [ -n "$STAGED_PRODUCT" ]; then
  case "$COMMIT_MSG" in
    *"[system-build]"*|*"GAP-FILL:"*)
      ;;
    *)
      echo ""
      echo "❌ §2.11 VIOLATION — COMMIT BLOCKED"
      echo ""
      echo "   Product files staged but commit message lacks [system-build] or GAP-FILL:"
      echo "$STAGED_PRODUCT" | sed 's/^/     /'
      echo ""
      exit 1
      ;;
  esac
fi

# ── 1b. §2.11 GAP-FILL honesty gate (HARD) ────────────────────────────────────
# The check above only verifies a GAP-FILL commit message EXISTS and is shaped
# right — it never verified the justification inside it was TRUE. A real incident
# (commit ac50782319) hand-authored Site Builder server code citing "no BuilderOS
# mission pack exists" when docs/products/site-builder/BUILD_QUEUE.json already had
# 33 tracked steps. This cross-checks any "no blueprint exists" style claim against
# the real BUILD_QUEUE.json files on disk before allowing the commit.
if ! node "$ROOT/scripts/verify-gap-fill-honesty.mjs" "$COMMIT_MSG_FILE"; then
  exit 1
fi

# ── 1c. SO-001 hand-authored size gate (HARD) ─────────────────────────────────
# The gates above verify a GAP-FILL message exists, is non-vague, and (for one
# specific lie-shape) isn't factually false -- but nothing stopped a GAP-FILL
# commit from hand-authoring a large, genuinely load-bearing services/routes/
# middleware module and just not tripping that one pattern. A 2026-07-20
# independent audit rated "SO-001 factory-required promise" 4/10 for exactly
# this reason. This adds a deterministic size threshold: a new file, or a real
# diff over 15 added lines, requires an explicit HAND-AUTHORED-JUSTIFICATION:
# line and gets durably logged to docs/products/builderos/GAP_FILL_LEDGER.json
# for later Architect/Chair review.
if ! node "$ROOT/scripts/verify-gap-fill-size-gate.mjs" "$COMMIT_MSG_FILE"; then
  exit 1
fi

# ── 2. §2.15 Intent Drift gate ────────────────────────────────────────────────
case "$COMMIT_MSG" in
  *"[system-build]"*|*"GAP-FILL:"*)
    STAGED_AMENDMENTS=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
      | grep -E '^docs/projects/AMENDMENT_.*\.md$' || true)
    if [ -n "$STAGED_AMENDMENTS" ]; then
      case "$COMMIT_MSG" in
        *"INTENT DRIFT:"*) ;;
        *)
          echo ""
          echo "❌ §2.15 / §2.11b DRIFT GATE — COMMIT BLOCKED"
          echo "   Add INTENT DRIFT: none (or asked X, delivered Y) to commit message."
          echo ""
          exit 1
          ;;
      esac
    fi
    ;;
esac

# ── 3. BP law — staged PASS product receipts (backup to pre-commit --staged) ───
STAGED_PASS_RECEIPT=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
  | grep '^products/receipts/' | grep '\.json$' || true)

if [ -n "$STAGED_PASS_RECEIPT" ]; then
  for f in $STAGED_PASS_RECEIPT; do
    if git show ":$f" 2>/dev/null | grep -q '"verdict"[[:space:]]*:[[:space:]]*"PASS"'; then
      case "$COMMIT_MSG" in
        *"BP law"*|*"bp_sync"*|*"BP_PRIORITY"*)
          ;;
        *)
          echo ""
          echo "❌ BP LAW — COMMIT BLOCKED"
          echo ""
          echo "   Staged PASS receipt: $f"
          echo "   Commit message must acknowledge BP sync (e.g. mention BP_PRIORITY / bp_sync)."
          echo "   Pre-commit also requires co-staged BP_PRIORITY + blueprint + founder JSON."
          echo ""
          exit 1
          ;;
      esac
    fi
  done
fi

# ── 4. FILE SYNOPSIS LAW (HARD — catches --no-verify bypass at commit-msg) ───
STAGED_INDEXABLE=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
  | grep -E '\.(js|mjs|ts|html|sql|md|css|sh|ya?ml|json)$' \
  | grep -v '^builderos-reboot/governance/REPO_FILE_SYNOPSIS_INDEX\.json$' || true)
STAGED_INDEX=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
  | grep -F 'builderos-reboot/governance/REPO_FILE_SYNOPSIS_INDEX.json' || true)

if [ -n "$STAGED_INDEXABLE" ] && [ -z "$STAGED_INDEX" ]; then
  echo ""
  echo "❌ FILE SYNOPSIS LAW — COMMIT BLOCKED"
  echo ""
  echo "   Indexable files staged without REPO_FILE_SYNOPSIS_INDEX.json."
  echo "   Run: npm run hooks:install && git commit (pre-commit auto-fixes)."
  echo "   git commit --no-verify is not allowed for indexable changes."
  echo ""
  exit 1
fi

exit 0
