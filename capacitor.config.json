{
  "appId": "org.hopkinsgroup.lifeos",
  "appName": "LifeOS",
  "webDir": "mobile/www",
  "server": {
    "url": "https://lumin-web-production-e3a9.up.railway.app/lifeos?native=1&layout=mobile&direct_system=1",
    "androidScheme": "https",
    "cleartext": false,
    "allowNavigation": [
      "lumin-web-production-e3a9.up.railway.app",
      "*.up.railway.app"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#0a0a0f",
      "showSpinner": false
    }
