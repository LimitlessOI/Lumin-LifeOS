{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRE_ARC_INPUT_PACKET",
  "type": "object",
  "required": ["schema", "mission_id", "manifest"],
  "properties": {
    "schema": { "type": "string", "const": "pre_arc_input_packet_v1" },
    "mission_id": { "type": "string", "minLength": 1 },
    "manifest": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact", "path", "exists"],
        "properties": {
          "artifact": { "type": "string" },
          "path": { "type": "string" },
          "exists": { "type": "boolean" },
          "sha256": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
