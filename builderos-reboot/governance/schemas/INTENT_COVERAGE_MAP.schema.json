{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "INTENT_COVERAGE_MAP",
  "type": "object",
  "required": ["schema", "intent_id", "dimensions"],
  "properties": {
    "schema": { "type": "string", "const": "intent_coverage_map_v1" },
    "intent_id": { "type": "string", "minLength": 1 },
    "tier": { "type": "integer" },
    "dimensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "coverage_level"],
        "properties": {
          "name": { "type": "string" },
          "coverage_level": {
            "type": "string",
            "enum": ["MISSING", "MENTIONED", "PARTIAL", "SUFFICIENT", "LOCKED", "PARKED"]
          },
          "load_bearing": { "type": "boolean" },
          "parked_reason": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
