{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ARC_RUN_RECEIPT",
  "type": "object",
  "required": ["schema", "mission_id", "run_at", "runner", "system_produced"],
  "properties": {
    "schema": { "type": "string", "const": "arc_run_receipt_v1" },
    "mission_id": { "type": "string" },
    "run_at": { "type": "string" },
    "runner": { "type": "string" },
    "entry_gate": { "type": "string", "enum": ["PASS", "FAIL", "SKIPPED"] },
    "simulation_summary": {
      "type": "object",
      "properties": {
        "blocking_gaps": { "type": "integer" },
        "clear_to_build": { "type": "boolean" }
      }
    },
    "system_produced": { "type": "boolean" },
    "blueprint_written": { "type": "boolean" }
  },
  "additionalProperties": true
}
