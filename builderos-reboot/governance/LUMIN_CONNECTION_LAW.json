  "enforcement": {
    "env_flag": "LUMIN_SINGLE_CONNECTION",
    "default": "1",
    "disabled_when": "LUMIN_SINGLE_CONNECTION=0",
    "http_status_retired": 410,
    "error_code": "LUMIN_LEGACY_PATH_RETIRED"
  },
  "retired_generative_paths": [
    {
      "id": "chat_messages",
      "method": "POST",
      "path_pattern": "/api/v1/lifeos/chat/threads/:id/messages",
