{
  "schema": "lumin_connection_law_v1",
  "updated_at": "2026-06-24",
  "operator_lock": "Adam — one true Lumin connection. Legacy comm paths are history-only.",
  "canonical": {
    "founder_message": {
      "method": "POST",
      "path": "/api/v1/lifeos/builderos/command-control/founder-interface/message",
