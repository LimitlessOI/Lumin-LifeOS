      "hist_domain": "History — read thread/messages GET only"
    },
    {
      "id": "chat_stream",
      "method": "POST",
      "path_pattern": "/api/v1/lifeos/chat/threads/:id/messages/stream",
      "was": "SSE streaming chat bypassing Chair",
      "hist_domain": "History"
    },
    {
      "id": "copilot_session_message",
      "method": "POST",
      "path_pattern": "/api/v1/lifeos/copilot/sessions/:id/message",
      "was": "Legacy copilot live session chat",
      "hist_domain": "History"
    }
  ],
  "history_only_surfaces": [
    {
      "path": "/overlay/lifeos-founder-interface.html",
      "status": "redirect",
      "redirect_to": "/overlay/lifeos-app.html"
