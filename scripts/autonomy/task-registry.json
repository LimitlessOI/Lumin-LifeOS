    "proof_artifacts": [],
    "ssot_refs": []
  },
  "run_migration": {
    "command": "node -e \"import('./db/index.js').then(m => m.runMigrations()).catch(console.error)\"",
    "requiredEnv": ["DATABASE_URL"],
    "verifiers": [],
    "proof_artifacts": [],
    "ssot_refs": []
  }
